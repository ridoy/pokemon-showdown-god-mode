{
  "name": "Pokémon Showdown God Mode",
  "version": "1.0.0",
  "manifest_version": 3,
  "description": "Embeds an interactive Gen 3 damage calculator into the Pokémon Showdown battle UI.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "default_locale": "en",
  "content_scripts": [
    {
      "matches": ["https://play.pokemonshowdown.com/*"],
      "js": ["dist/bundle.js"],
      "css": ["css/calc.css"],
      "world": "MAIN",
      "run_at": "document_idle"
    }
  ]
}
